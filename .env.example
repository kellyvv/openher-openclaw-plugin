# ─── OpenHer Backend Configuration ───
# Copy this file to .env and fill in at least one LLM provider key.
#
#   cp .env.example .env

# ─── LLM Providers (set at least one) ───

# MiniMax (recommended — zero narration, perfect persona proxy)
MINIMAX_LLM_API_KEY=
# MINIMAX_GROUP_ID=           # Optional, for MiniMax v2 API

# Google Gemini
# GEMINI_API_KEY=

# Anthropic Claude
# ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Alibaba Qwen (DashScope)
# DASHSCOPE_API_KEY=

# Moonshot
# MOONSHOT_API_KEY=

# StepFun
# STEPFUN_API_KEY=

# Ollama (local, no key needed)
# DEFAULT_PROVIDER=ollama
# DEFAULT_MODEL=qwen2.5:7b

# ─── TTS (optional) ───
# MiniMax TTS (NOTE: separate key from LLM above)
# MINIMAX_API_KEY=

# ─── Memory (optional) ───
# EverMemOS long-term memory (Layer 3 — optional)
# EVERMEMOS_BASE_URL=http://localhost:8080
# EVERMEMOS_API_KEY=

# ─── Defaults ───
DEFAULT_PROVIDER=minimax
DEFAULT_MODEL=MiniMax-M2.7
